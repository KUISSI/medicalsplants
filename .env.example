
properties
# ============================================================
# ENVIRONMENT VARIABLES - MEDICALS PLANTS
# ============================================================
# Copy this file to .env and update values
# Command: cp .env. example .env
# ============================================================

# ============================================================
# APPLICATION
# ============================================================
APP_NAME=Medicals Plants
APP_URL=http://localhost:8080
SPRING_PROFILES_ACTIVE=dev

# ============================================================
# SERVER
# ============================================================
SERVER_PORT=8080

# ============================================================
# DATABASE - PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medicalsplants_dev
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Generate a secure key with: openssl rand -base64 64
# IMPORTANT: Change this value in production!
JWT_SECRET=mySecretKeyForJwtTokenGenerationMustBeAtLeast256BitsLong123456789
# Access token expiration: 15 minutes (in milliseconds)
JWT_EXPIRATION=900000
# Refresh token expiration: 7 days (in milliseconds)
JWT_REFRESH_EXPIRATION=604800000

# ============================================================
# EMAIL - SMTP
# ============================================================
# For development, use MailHog (localhost: 1025)
# For production, configure a real SMTP server
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4200,http://localhost:4201

# ============================================================
# DOCKER (optional - used by docker-compose)
# ============================================================
POSTGRES_DB=medicalsplants_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PGADMIN_EMAIL=gkuissi@gmail.com
PGADMIN_PASSWORD=admin123