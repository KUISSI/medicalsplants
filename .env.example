# ============================================================
# ENVIRONMENT VARIABLES - MEDICALS PLANTS
# ============================================================
# Copy this file to .env and update values

# Application
APP_NAME=Medicals Plants
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medicalsplants_dev
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Authentication
JWT_SECRET=your-secret-key-min-256-bits-change-in-production
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Email (MailHog for development)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:4201
