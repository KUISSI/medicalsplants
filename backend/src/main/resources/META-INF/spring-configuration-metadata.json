{
  "groups": [
    {
      "name": "app.jwt",
      "type": "com.medicalsplants.config.JwtProperties",
      "sourceType": "com.medicalsplants.config.JwtProperties"
    },
    {
      "name": "app",
      "type": "com.medicalsplants.config.AppProperties",
      "sourceType": "com.medicalsplants.config.AppProperties"
    },
    {
      "name": "app.cors",
      "type": "com.medicalsplants.config.AppProperties$Cors",
      "sourceType": "com.medicalsplants.config.AppProperties$Cors"
    }
  ],
  "properties": [
    {
      "name": "app.jwt.secret",
      "type": "java.lang.String",
      "description": "Secret key for JWT token generation."
    },
    {
      "name": "app.jwt.expiration",
      "type": "java.lang.Long",
      "description": "Expiration time for JWT tokens (in ms)."
    },
    {
      "name": "app.jwt.refresh-expiration",
      "type": "java.lang.Long",
      "description": "Expiration time for JWT refresh tokens (in ms)."
    },
    {
      "name": "app.jwt.token-prefix",
      "type": "java.lang.String",
      "description": "Prefix for JWT tokens (default: Bearer )."
    },
    {
      "name": "app.jwt.header-name",
      "type": "java.lang.String",
      "description": "Header name for JWT tokens (default: Authorization)."
    },
    {
      "name": "app.name",
      "type": "java.lang.String",
      "description": "Application name."
    },
    {
      "name": "app.url",
      "type": "java.lang.String",
      "description": "Application base URL."
    },
    {
      "name": "app.cors.allowed-origins",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed origins for CORS."
    },
    {
      "name": "app.cors.max-age",
      "type": "java.lang.Long",
      "description": "CORS max age in seconds."
    }
  ],
  "hints": []
}
